{
  "name": "riska-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run verify:policy-human-verifier && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:export:orphan-policy": "node scripts/export-orphan-policy-table.cjs",
    "db:migrate:deploy": "prisma migrate deploy",
    "contracts:compile": "hardhat compile --config hardhat.config.cjs",
    "contracts:test": "hardhat test --config hardhat.config.cjs",
    "test:policy-human": "node --experimental-strip-types --test test/policy-human-proof.test.ts",
    "test:web3": "node --experimental-strip-types --test test/wallet-client.test.ts",
    "test:fork:seed-multi-policy": "node scripts/seed-deployed-multi-policy-fork.cjs",
    "verify:policy-human-verifier": "node scripts/validate-policy-human-verifier.cjs",
    "wallet:create:worldchain-sepolia": "node scripts/create-worldchain-test-wallet.cjs",
    "contracts:deploy:worldchain-sepolia": "hardhat run --config hardhat.config.cjs scripts/deploy-worldchain-sepolia.cjs --network worldchainSepolia",
    "contracts:deploy:worldchain-sepolia:prod-test": "RISKA_DEPLOYMENT_DIRECTORY=worldchain-sepolia-prod-test hardhat run --config hardhat.config.cjs scripts/deploy-worldchain-sepolia.cjs --network worldchainSepolia",
    "contracts:rotate-policy-verifier:worldchain-sepolia": "hardhat run --config hardhat.config.cjs scripts/rotate-policy-human-verifier.cjs --network worldchainSepolia",
    "contracts:configure:morpho-usdc:worldchain": "hardhat run --config hardhat.config.cjs scripts/configure-morpho-usdc-worldchain.cjs --network worldchain",
    "contracts:deploy:mock-auxiliary-tokens:worldchain-sepolia": "hardhat run --config hardhat.config.cjs scripts/deploy-mock-auxiliary-tokens.cjs --network worldchainSepolia",
    "contracts:deploy:testnet-token-faucet:worldchain-sepolia": "hardhat run --config hardhat.config.cjs scripts/deploy-testnet-token-faucet.cjs --network worldchainSepolia"
  },
  "dependencies": {
    "@metamask/sdk": "^0.34.0",
    "@prisma/client": "5.13.0",
    "@worldcoin/idkit": "^4.1.6",
    "@worldcoin/minikit-js": "^2.0.3",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "^2.51.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "20.12.7",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.4",
    "hardhat": "^2.28.0",
    "postcss": "8.4.38",
    "prisma": "5.13.0",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5"
  }
}
