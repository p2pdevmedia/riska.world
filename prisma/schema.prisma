generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PolicyHumanReservation {
  id                    String   @id @default(cuid())
  action                String
  nullifierHash         String
  walletAddress         String
  protocolVersion       String
  credentialIdentifiers Json
  createdAt             DateTime @default(now())
  expiresAt             DateTime

  @@unique([action, nullifierHash])
  @@index([walletAddress])
}
